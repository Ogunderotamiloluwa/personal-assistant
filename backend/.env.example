# Backend Environment Variables
NODE_ENV=development
PORT=5001
HOSTNAME=localhost

# MongoDB Connection (optional - will use file storage as fallback)
MONGODB_URI=mongodb://localhost:27017/personal-asst

# OpenAI API (optional - AI features)
OPENAI_API_KEY=

# Hugging Face API (optional - AI fallback)
HUGGING_FACE_TOKEN=

# Client URLs for CORS
CLIENT_URL=http://localhost:3000,http://localhost:5173,http://localhost:5000

# Web Push Notifications (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
